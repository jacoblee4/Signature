if (!html) {
    gs.info('SIGNATURE TESTING: No HTML generated - check date range has closed_complete child records');
} else {
    gs.info('SIGNATURE TESTING: HTML generated, length = ' + html.length);

    var hfInfo = {
        'PageSize': 'A4',
        'Orientation': 'LANDSCAPE',
        'GeneratePageNumber': 'true',
