generateAndEmailManagementReport: function(startDate, endDate, recipientSysId) {
        var logs = [];

        // Get anchor record
        var anchorGr = new GlideRecord('x_banun_bunow_si_0_signature_request');
        anchorGr.addQuery('state', '3');
        anchorGr.orderByDesc('closed_at');
        anchorGr.setLimit(1);
        anchorGr.query();

        if (!anchorGr.next()) {
            logs.push('ERROR: No closed_complete records found to use as attachment anchor');
            return {
                success: false,
                message: 'No closed records found. Cannot generate report.',
                logs: logs
            };
        }

        var anchorSysId = anchorGr.getValue('sys_id');
        logs.push('OK: Anchor record found - ' + anchorSysId);

        // Generate HTML
        logs.push('INFO: Calling buildManagementReportHTML for ' + startDate + ' to ' + endDate);
        var html = this.buildManagementReportHTML(startDate, endDate);
        if (!html) {
            logs.push('ERROR: buildManagementReportHTML returned null - no data in date range');
            return {
                success: false,
                message: 'No data found for the selected date range.',
                logs: logs
            };
        }
        logs.push('OK: HTML generated, length = ' + html.length);

        // Generate PDF
        var hfInfo = {
            'PageSize': 'A4',
            'Orientation': 'LANDSCAPE',
            'GeneratePageNumber': 'true',
            'TopOrBottomMargin': '20',
            'LeftOrRightMargin': '20'
        };

        var pdfFileName = 'Authority_Limits_Management_Report_' + startDate + '_to_' + endDate + '.pdf';
        logs.push('INFO: Calling PDF API with filename ' + pdfFileName);

        var pdfAPI = new sn_pdfgeneratorutils.PDFGenerationAPI();
        var result = pdfAPI.convertToPDFWithHeaderFooter(
            html,
            'x_banun_bunow_si_0_signature_request',
            anchorSysId,
            pdfFileName,
            hfInfo
        );

        logs.push('INFO: Raw PDF result = ' + JSON.stringify(result));

        if (!result) {
            logs.push('ERROR: PDF result is null/undefined');
            return {
                success: false,
                message: 'PDF generation failed. Please contact your administrator.',
                logs: logs
            };
        }

        // Log every key in result so we can see exact structure
        for (var key in result) {
            logs.push('INFO: result.' + key + ' = ' + result[key]);
        }

        if (!result.attachment_id) {
            logs.push('ERROR: result.attachment_id is missing or empty');
            return {
                success: false,
                message: 'PDF generation failed. Please contact your administrator.',
                logs: logs
            };
        }
        logs.push('OK: PDF generated, attachment_id = ' + result.attachment_id);

        // Get recipient
        var userGr = new GlideRecord('sys_user');
        if (!userGr.get(recipientSysId)) {
            logs.push('ERROR: Could not find user record for sys_id ' + recipientSysId);
            return {
                success: false,
                message: 'Could not resolve recipient user.',
                logs: logs
            };
        }

        var recipientEmail = userGr.getValue('email');
        var recipientName = userGr.getValue('first_name') || 'User';
        logs.push('OK: Recipient resolved - ' + recipientEmail);

        if (!recipientEmail) {
            logs.push('ERROR: User has no email address');
            return {
                success: false,
                message: 'No email address found for your user account.',
                logs: logs
            };
        }

        // Send email
        logs.push('INFO: Sending email to ' + recipientEmail);
        var sm = new GlideEmail();
sm.setTo(recipientEmail);
sm.setSubject('Authority Limits Management Report: ' + startDate + ' to ' + endDate);
sm.setBody(
    'Hello ' + recipientName + ',\n\n' +
    'Please find attached the Authority Limits Management Report for the period ' + startDate + ' to ' + endDate + '.\n\n' +
    'This report was generated on ' + new GlideDateTime().getDisplayValue() + '.\n\n' +
    'This is an automated message. Please do not reply to this email.'
);
sm.addAttachment(
    'x_banun_bunow_si_0_signature_request',
    anchorSysId,
    pdfFileName
);
sm.save();
logs.push('OK: Email queued successfully');

        // Clean up attachment
        logs.push('INFO: Cleaning up attachment from anchor record');
        var attGr = new GlideRecord('sys_attachment');
        attGr.addQuery('table_name', 'x_banun_bunow_si_0_signature_request');
        attGr.addQuery('table_sys_id', anchorSysId);
        attGr.addQuery('file_name', pdfFileName);
        attGr.query();
        if (attGr.next()) {
            attGr.deleteRecord();
            logs.push('OK: Attachment cleaned up');
        } else {
            logs.push('WARN: Attachment not found for cleanup - may have already been removed');
        }

        return {
            success: true,
            message: 'Report sent to ' + recipientEmail,
            logs: logs
        };
    },
