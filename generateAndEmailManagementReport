generateAndEmailManagementReport: function(startDate, endDate, recipientEmail) {

    // Find the dedicated anchor system property used as the PDF attachment target
    var anchorGr = new GlideRecord('sys_properties');
    anchorGr.addQuery('name', 'x_banun_bunow_si_0.management_report_anchor');
    anchorGr.query();
    if (!anchorGr.next()) {
        return {
            success: false,
            message: 'Report anchor property not found. Please contact your administrator.'
        };
    }
    var anchorSysId = anchorGr.getValue('sys_id');

    // Remove any leftover attachments from previous report generations
    var cleanGr = new GlideRecord('sys_attachment');
    cleanGr.addQuery('table_name', 'sys_properties');
    cleanGr.addQuery('table_sys_id', anchorSysId);
    cleanGr.query();
    while (cleanGr.next()) {
        cleanGr.deleteRecord();
    }

    // Generate the report HTML
    var html = this.buildManagementReportHTML(startDate, endDate);
    if (!html) {
        return {
            success: false,
            message: 'No data found for the selected date range.'
        };
    }

    // Generate the PDF and attach it to the anchor property record
    var hfInfo = {
        'PageSize': 'A4',
        'Orientation': 'LANDSCAPE',
        'GeneratePageNumber': 'true',
        'TopOrBottomMargin': '20',
        'LeftOrRightMargin': '20'
    };

    var pdfFileName = 'Authority_Limits_Management_Report_' + startDate + '_to_' + endDate + '.pdf';
    var pdfAPI = new sn_pdfgeneratorutils.PDFGenerationAPI();
    var result = pdfAPI.convertToPDFWithHeaderFooter(
        html,
        'sys_properties',
        anchorSysId,
        pdfFileName,
        hfInfo
    );

    if (!result || !result.attachment_id) {
        return {
            success: false,
            message: 'PDF generation failed. Please contact your administrator.'
        };
    }

    if (!recipientEmail) {
        return {
            success: false,
            message: 'No recipient email provided.'
        };
    }

    // Fire the event — the notification picks up the attachment and emails the report
    gs.eventQueue(
        'x_banun_bunow_si_0.management_report_gen',
        anchorGr,
        recipientEmail,
        startDate + ' to ' + endDate
    );

    return {
        success: true,
        message: 'Report sent to ' + recipientEmail
    };
},
